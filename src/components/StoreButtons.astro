---
interface Props {
    variant?: "light" | "dark";
    class?: string;
}

const { variant = "light", class: className = "" } = Astro.props;

const playStyles =
    variant === "light"
        ? "border-slate-950 bg-slate-950 hover:bg-slate-900"
        : "border-white/0 bg-white hover:bg-blue-50";
const playLabelColor = variant === "light" ? "text-slate-300" : "text-slate-500";
const playNameColor = variant === "light" ? "text-white" : "text-slate-900";

const appleStyles =
    variant === "light"
        ? "border-slate-200 bg-white hover:border-slate-300"
        : "border-white/30 bg-white/10 hover:bg-white/20";
const appleIconColor = variant === "light" ? "text-slate-700" : "text-white";
const appleLabelColor = variant === "light" ? "text-slate-500" : "text-blue-100";
const appleNameColor = variant === "light" ? "text-slate-700" : "text-white";
---

<div class={`flex flex-wrap items-center gap-3 ${className}`}>
    <a
        href="https://play.google.com/store/apps/details?id=ventures.layline.glu"
        class={`group inline-flex items-center gap-3 rounded-2xl border px-5 py-3 shadow-[0_18px_35px_-24px_rgba(15,23,42,0.55)] transition-all duration-300 ease-out-quint hover:-translate-y-0.5 hover:shadow-[0_24px_45px_-22px_rgba(15,23,42,0.55)] ${playStyles}`}
    >
        <svg
            class="h-6 w-6 shrink-0"
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
        >
            <path
                d="M3.18 23.76c.4.22.85.24 1.27.05l12.55-7.03-2.88-2.89L3.18 23.76Z"
                fill="#EA4335"></path>
            <path
                d="M20.82 10.26 17.7 8.47 14.5 11.6l3.2 3.17 3.13-1.75c.89-.5.89-1.77-.01-2.76Z"
                fill="#FBBC04"></path>
            <path
                d="M3.18.24C2.76.03 2.28.07 1.9.34 1.53.6 1.33 1.02 1.33 1.5v21c0 .48.2.9.57 1.16.37.27.85.31 1.27.1L14.5 11.6 3.18.24Z"
                fill="#4285F4"></path>
            <path
                d="M14.5 11.6 3.18.24c-.03-.03-.06-.05-.09-.07L14.5 11.6Zm0 0 3.2 3.17-12.55 7.03c-.41.23-.86.25-1.27.05L14.5 11.6Z"
                fill="#34A853"></path>
            <path
                d="m3.09.17-.09.07L14.5 11.6 3.18.24C2.97.1 2.7.03 2.42.03 2.32.03 2.25.07 3.09.17Z"
                fill="#34A853"></path>
            <path
                d="M1.33 1.5c0-.48.2-.9.57-1.16.08-.06.17-.1.26-.14L14.5 11.6 1.9 23.66c-.37-.26-.57-.68-.57-1.16V1.5Z"
                fill="#4285F4"></path>
        </svg>
        <span class="text-left">
            <span class={`block text-[10px] font-medium leading-none ${playLabelColor}`}>
                Download now on
            </span>
            <span class={`mt-0.5 block font-body text-[15px] font-semibold leading-none ${playNameColor}`}>
                Google Play
            </span>
        </span>
    </a>

    <a
        href="https://apps.apple.com/us/app/glu-glp-1-weight-loss-tracker/id6761419458"
        class={`group inline-flex items-center gap-3 rounded-2xl border px-5 py-3 shadow-[0_18px_35px_-24px_rgba(15,23,42,0.18)] transition-all duration-300 ease-out-quint hover:-translate-y-0.5 hover:shadow-[0_24px_45px_-22px_rgba(15,23,42,0.3)] ${appleStyles}`}
    >
        <svg
            class={`h-6 w-6 shrink-0 ${appleIconColor}`}
            viewBox="0 0 24 24"
            fill="currentColor"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
        >
            <path
                d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"
            ></path>
        </svg>
        <span class="text-left">
            <span class={`block text-[10px] font-medium leading-none ${appleLabelColor}`}>
                Download now on
            </span>
            <span class={`mt-0.5 block font-body text-[15px] font-semibold leading-none ${appleNameColor}`}>
                App Store
            </span>
        </span>
    </a>
</div>
