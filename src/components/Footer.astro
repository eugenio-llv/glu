---
interface Props {
  showFeaturedIn?: boolean;
}

const { showFeaturedIn: _showFeaturedIn = false } = Astro.props;
---

<footer class="border-t border-slate-100 bg-white">
  <div class="mx-auto max-w-5xl px-6 py-10 sm:px-8 sm:py-12">
    <div class="flex flex-col items-center justify-between gap-4 text-sm text-slate-600 sm:flex-row">
      <p>&copy; 2026 Layline Ventures</p>
      <div class="flex flex-wrap items-center justify-center gap-6">
        <a href="/terms" class="hover:text-slate-900 transition-colors">Terms</a>
        <a href="/privacy" class="hover:text-slate-900 transition-colors">Privacy</a>
        <a href="/support" class="hover:text-slate-900 transition-colors">Support</a>
      </div>
    </div>

    <div class="mt-8 h-px w-full bg-linear-to-r from-transparent via-slate-200 to-transparent"></div>

    <div class="mx-auto mt-6 max-w-4xl text-center">
      <p class="text-xs font-medium uppercase tracking-[0.18em] text-slate-400">Medical Disclaimer</p>
      <p class="mt-3 text-sm leading-relaxed text-slate-500">
        Glu is intended for personal tracking and educational use only. It does not provide medical advice, diagnosis, or treatment, and should not be used as a substitute for guidance from a licensed physician or other qualified healthcare professional. Always consult your healthcare provider before making decisions about medication, dosing, nutrition, exercise, or any aspect of your treatment plan.
      </p>
    </div>
  </div>
</footer>
