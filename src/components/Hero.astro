---
import { Image } from "astro:assets";
import StoreButtons from "./StoreButtons.astro";
import homeTrackers from "../assets/landing-page/home_trackers.png";
import journeyInsight from "../assets/landing-page/journey_insight.png";
import portionCheck from "../assets/landing-page/portion_check.png";
import progressAll from "../assets/landing-page/progress_all.png";
import glowUp from "../assets/landing-page/glow_up.png";
import progressWeight from "../assets/landing-page/progress_weight.png";

const primarySlide = { src: homeTrackers, alt: "Glu home trackers screen" };
const carouselSlides = [
    { src: journeyInsight, alt: "Glu journey insight screen" },
    { src: portionCheck, alt: "Glu portion check screen" },
    { src: progressAll, alt: "Glu progress overview screen" },
    { src: progressWeight, alt: "Glu progress weight screen" },
    { src: glowUp, alt: "Glu glow up screen" },
];
---

<section
    class="hero-premium-bg relative min-h-screen overflow-hidden px-6 pb-20 pt-28 sm:px-10 lg:py-0"
>
    <div
        class="relative z-10 mx-auto flex w-full max-w-screen-2xl items-center lg:min-h-screen"
    >
        <div
            class="flex w-full flex-col items-center gap-16 lg:flex-row lg:gap-24"
        >
            <div class="w-full flex-1 text-center lg:text-left">
                <div
                    class="hero-enter mb-9 inline-flex items-center gap-2 rounded-full border border-blue-100 bg-white/85 px-4 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-ink-soft"
                    style="--enter-delay: 0s"
                >
                    <span class="relative flex h-2 w-2">
                        <span
                            class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-60 motion-reduce:hidden"
                        ></span>
                        <span
                            class="relative inline-flex h-2 w-2 rounded-full bg-emerald-500"
                        ></span>
                    </span>
                    Now on iPhone and Android
                </div>

                <h1
                    class="hero-enter mx-auto max-w-2xl font-display text-[clamp(2.6rem,6vw,4.6rem)] font-bold leading-[1.03] tracking-[-0.03em] text-ink lg:mx-0"
                    style="--enter-delay: 0.08s"
                >
                    Glu, the GLP&#8209;1 tracker for daily progress
                </h1>

                <p
                    class="hero-enter mx-auto mt-7 max-w-xl font-body text-base leading-relaxed text-ink-soft sm:text-xl lg:mx-0"
                    style="--enter-delay: 0.18s"
                >
                    One clear place to track medication, meals, movement,
                    symptoms, reminders, and progress: before, during, and
                    after treatment.
                </p>

                <div class="hero-enter mt-10" style="--enter-delay: 0.28s">
                    <StoreButtons class="justify-center lg:justify-start" />
                </div>

                <p
                    class="hero-enter mt-7 text-[13px] text-ink-faint"
                    style="--enter-delay: 0.38s"
                >
                    Works with all GLP&#8209;1 shots and pills: Zepbound&reg;,
                    Mounjaro&reg;, Ozempic&reg;, Wegovy&reg;, Rybelsus&reg;,
                    and more.
                </p>
            </div>

            <div class="w-full flex-1 lg:mt-0">
                <div
                    class="hero-enter-phone flex items-center justify-center"
                    style="--enter-delay: 0.25s"
                >
                    <div
                        class="w-full max-w-[360px] rounded-[46px] border border-white bg-white p-[7px] shadow-[0_60px_120px_-48px_rgba(30,58,138,0.4)] lg:max-w-[430px]"
                    >
                        <div
                            data-carousel
                            class="relative overflow-hidden rounded-[39px] bg-slate-50"
                            aria-label="Glu app screenshots"
                        >
                            <div
                                class="relative aspect-[1250/2532] w-full overflow-hidden"
                            >
                                <Image
                                    data-carousel-slide
                                    src={primarySlide.src}
                                    alt={primarySlide.alt}
                                    class="absolute inset-0 h-full w-full object-cover object-top transition-all duration-700 ease-out-quint motion-reduce:transition-none opacity-100"
                                    widths={[480, 860]}
                                    sizes="(min-width: 1024px) 430px, 360px"
                                    format="webp"
                                    loading="eager"
                                    fetchpriority="high"
                                    decoding="async"
                                    data-carousel-index={0}
                                />
                                {
                                    carouselSlides.map((slide, index) => (
                                        <Image
                                            data-carousel-slide
                                            src={slide.src}
                                            alt={slide.alt}
                                            class="absolute inset-0 h-full w-full object-cover object-top transition-all duration-700 ease-out-quint motion-reduce:transition-none opacity-0"
                                            widths={[480, 860]}
                                            sizes="(min-width: 1024px) 430px, 360px"
                                            format="webp"
                                            loading="lazy"
                                            fetchpriority="low"
                                            decoding="async"
                                            data-carousel-index={index + 1}
                                        />
                                    ))
                                }
                            </div>

                            <div
                                class="absolute inset-x-0 top-3.5 hidden items-center justify-center gap-3 sm:flex"
                            >
                                <button
                                    type="button"
                                    data-carousel-prev
                                    aria-label="Previous screenshot"
                                    class="flex h-6 w-6 items-center justify-center rounded-full bg-white/75 text-slate-600 shadow-[0_0_0_1px_rgba(15,23,42,0.08)] backdrop-blur transition-all duration-300 hover:bg-white"
                                >
                                    <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
                                </button>

                                <div class="flex items-center gap-2">
                                    {
                                        [primarySlide, ...carouselSlides].map((slide, index) => (
                                            <button
                                                type="button"
                                                data-carousel-dot
                                                aria-label={`Show screenshot ${index + 1}`}
                                                class={`h-2.5 rounded-full bg-slate-300/80 transition-all duration-300 backdrop-blur ${
                                                    index === 0
                                                        ? "w-8 bg-white shadow-[0_0_0_1px_rgba(15,23,42,0.1)]"
                                                        : "w-2.5"
                                                }`}
                                                data-carousel-target={index}
                                            />
                                        ))
                                    }
                                </div>

                                <button
                                    type="button"
                                    data-carousel-next
                                    aria-label="Next screenshot"
                                    class="flex h-6 w-6 items-center justify-center rounded-full bg-white/75 text-slate-600 shadow-[0_0_0_1px_rgba(15,23,42,0.08)] backdrop-blur transition-all duration-300 hover:bg-white"
                                >
                                    <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
                                </button>
                            </div>

                            <div class="absolute inset-x-0 top-3.5 flex items-center justify-center gap-2 sm:hidden">
                                {
                                    [primarySlide, ...carouselSlides].map((slide, index) => (
                                        <button
                                            type="button"
                                            data-carousel-dot
                                            aria-label={`Show screenshot ${index + 1}`}
                                            class={`h-2.5 rounded-full bg-slate-300/80 transition-all duration-300 backdrop-blur ${
                                                index === 0
                                                    ? "w-8 bg-white shadow-[0_0_0_1px_rgba(15,23,42,0.1)]"
                                                    : "w-2.5"
                                            }`}
                                            data-carousel-target={index}
                                        />
                                    ))
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script is:inline>
    const initCarousel = () => {
        const carousel = document.querySelector("[data-carousel]");

        if (!(carousel instanceof HTMLElement)) return;

        const slides = Array.from(
            carousel.querySelectorAll("[data-carousel-slide]"),
        );
        const dots = Array.from(
            carousel.querySelectorAll("[data-carousel-dot]"),
        );
        const prefersReducedMotion = window.matchMedia(
            "(prefers-reduced-motion: reduce)",
        ).matches;

        if (slides.length === 0) return;

        let activeIndex = 0;
        let timer = null;

        const setActive = (index) => {
            activeIndex = index;

            slides.forEach((slide, slideIndex) => {
                const isActive = slideIndex === index;
                slide.style.opacity = isActive ? "1" : "0";
                slide.style.transform = isActive
                    ? "scale(1)"
                    : "scale(1.035)";
                slide.style.pointerEvents = isActive ? "auto" : "none";
                slide.setAttribute(
                    "aria-hidden",
                    isActive ? "false" : "true",
                );
            });

            dots.forEach((dot, dotIndex) => {
                const isActive = dotIndex === index;
                dot.classList.toggle("w-8", isActive);
                dot.classList.toggle("w-2.5", !isActive);
                dot.classList.toggle("bg-slate-900", isActive);
                dot.classList.toggle("bg-slate-300", !isActive);
                dot.setAttribute(
                    "aria-pressed",
                    isActive ? "true" : "false",
                );
            });
        };

        const start = () => {
            if (prefersReducedMotion || slides.length < 2 || timer !== null) return;
            timer = window.setInterval(() => {
                setActive((activeIndex + 1) % slides.length);
            }, 3500);
        };

        const stop = () => {
            if (timer !== null) {
                window.clearInterval(timer);
                timer = null;
            }
        };

        setActive(0);
        start();

        carousel.addEventListener("mouseenter", stop);
        carousel.addEventListener("mouseleave", start);
        carousel.addEventListener("focusin", stop);
        carousel.addEventListener("focusout", start);

        dots.forEach((dot) => {
            dot.addEventListener("click", () => {
                const target = Number(
                    dot.getAttribute("data-carousel-target"),
                );
                if (Number.isFinite(target)) {
                    stop();
                    setActive(target);
                    start();
                }
            });
        });

        const prevBtn = carousel.querySelector("[data-carousel-prev]");
        const nextBtn = carousel.querySelector("[data-carousel-next]");
        prevBtn?.addEventListener("click", () => {
            stop();
            setActive((activeIndex - 1 + slides.length) % slides.length);
            start();
        });
        nextBtn?.addEventListener("click", () => {
            stop();
            setActive((activeIndex + 1) % slides.length);
            start();
        });

        let touchStartX = null;
        carousel.addEventListener("touchstart", (e) => {
            touchStartX = e.touches[0].clientX;
        }, { passive: true });
        carousel.addEventListener("touchend", (e) => {
            if (touchStartX === null) return;
            const delta = e.changedTouches[0].clientX - touchStartX;
            touchStartX = null;
            if (Math.abs(delta) < 40) return;
            stop();
            setActive(delta < 0
                ? (activeIndex + 1) % slides.length
                : (activeIndex - 1 + slides.length) % slides.length);
            start();
        }, { passive: true });
    };

    if ("requestIdleCallback" in window) {
        window.requestIdleCallback(initCarousel, { timeout: 1500 });
    } else {
        window.addEventListener("load", initCarousel, { once: true });
    }
</script>
