---
import phoneDemo from '../assets/landing-page/phone-demo.png';
---

<section class="hero-premium-bg relative min-h-screen overflow-hidden px-6 py-16 lg:py-0">
  <div class="relative z-10 mx-auto flex min-h-screen w-full max-w-screen-2xl items-center">
    <div class="flex w-full flex-col items-center gap-16 lg:flex-row lg:gap-20">
      <div class="w-full flex-1 text-center lg:text-left">
        <div class="mb-8 inline-flex items-center gap-2 rounded-full border border-blue-100 bg-white/80 px-4 py-2 text-xs font-semibold uppercase tracking-[0.18em] text-slate-600 shadow-[0_10px_30px_-24px_rgba(15,23,42,0.8)] backdrop-blur">
          <span class="h-2 w-2 rounded-full bg-green-500"></span>
          Available on iPhone + Android
        </div>

        <div class="mb-8 flex items-center justify-center gap-3 lg:justify-start">
          <img
            src="/app_icon.png"
            alt="Glu icon"
            class="h-11 w-11 rounded-xl shadow-[0_16px_32px_-20px_rgba(37,99,235,0.45)]"
            width="44"
            height="44"
          />
          <div>
            <div class="font-sora text-2xl font-semibold tracking-tight text-slate-900">Glu</div>
            <div class="text-xs font-semibold uppercase tracking-[0.22em] text-blue-700">GLP-1 Tracker</div>
          </div>
        </div>

        <h1 class="font-sora text-3xl font-semibold leading-[1.02] tracking-tight text-slate-900 sm:text-5xl lg:text-[3.4rem] xl:text-[3.9rem]">
          Support for every stage of your
          <span class="text-slate-400"> GLP-1</span> journey.
        </h1>

        <p class="mt-7 font-dm-sans text-sm leading-relaxed text-slate-600 sm:text-xl lg:max-w-xl">
          Glu gives you a simple, convenient way to track medication, meals, movement,
          symptoms, and progress before, during, and after treatment.
        </p>

        <div class="mt-6 w-full max-w-2xl rounded-[24px] border border-slate-200/80 bg-white/52 px-4 py-4 shadow-[0_20px_45px_-36px_rgba(15,23,42,0.18)] backdrop-blur sm:px-5">
          <div class="flex flex-col gap-2 sm:flex-row sm:items-baseline sm:justify-between">
            <div class="flex items-center gap-2">
              <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-blue-50 text-blue-600">
                <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"></path>
                  <path d="m9 12 2 2 4-4"></path>
                </svg>
              </span>
              <p class="font-sora text-sm font-semibold tracking-tight text-slate-900">
                Works with all GLP-1 shots and pills
              </p>
            </div>
            <p class="text-xs text-slate-500">
              ZepboundÂź, MounjaroÂź, OzempicÂź, WegovyÂź, RybelsusÂź, and more
            </p>
          </div>
        </div>

        <div class="mt-6 flex flex-wrap justify-center gap-2 lg:justify-start">
          <span class="rounded-full border border-blue-100 bg-white/80 px-3 py-1.5 text-xs font-medium text-slate-600">Dose & refill reminders</span>
          <span class="rounded-full border border-blue-100 bg-white/80 px-3 py-1.5 text-xs font-medium text-slate-600">Meals, water & movement</span>
          <span class="rounded-full border border-blue-100 bg-white/80 px-3 py-1.5 text-xs font-medium text-slate-600">Progress you can feel</span>
        </div>

        <div class="mt-6 flex flex-wrap justify-center gap-3 lg:justify-start">
          <a
            href="https://play.google.com/store/apps/details?id=ventures.layline.glu"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-3 rounded-xl border border-slate-200/80 bg-slate-900 px-5 py-3 shadow-[0_18px_35px_-24px_rgba(15,23,42,0.55)]"
          >
            <svg class="h-6 w-6 shrink-0" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M3.18 23.76c.4.22.85.24 1.27.05l12.55-7.03-2.88-2.89L3.18 23.76Z" fill="#EA4335"></path>
              <path d="M20.82 10.26 17.7 8.47 14.5 11.6l3.2 3.17 3.13-1.75c.89-.5.89-1.77-.01-2.76Z" fill="#FBBC04"></path>
              <path d="M3.18.24C2.76.03 2.28.07 1.9.34 1.53.6 1.33 1.02 1.33 1.5v21c0 .48.2.9.57 1.16.37.27.85.31 1.27.1L14.5 11.6 3.18.24Z" fill="#4285F4"></path>
              <path d="M14.5 11.6 3.18.24c-.03-.03-.06-.05-.09-.07L14.5 11.6Zm0 0 3.2 3.17-12.55 7.03c-.41.23-.86.25-1.27.05L14.5 11.6Z" fill="#34A853"></path>
              <path d="m3.09.17-.09.07L14.5 11.6 3.18.24C2.97.1 2.7.03 2.42.03 2.32.03 2.25.07 3.09.17Z" fill="#34A853"></path>
              <path d="M1.33 1.5c0-.48.2-.9.57-1.16.08-.06.17-.1.26-.14L14.5 11.6 1.9 23.66c-.37-.26-.57-.68-.57-1.16V1.5Z" fill="#4285F4"></path>
            </svg>
            <div class="text-left">
              <div class="text-[10px] font-medium leading-none text-slate-400">Download now on</div>
              <div class="mt-0.5 font-dm-sans text-[15px] font-semibold leading-none text-white">Google Play</div>
            </div>
          </a>

          <a
            href="https://apps.apple.com/br/app/glu-glp-1-weight-loss-tracker/id6761419458"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-3 rounded-xl border border-slate-200/80 bg-white px-5 py-3 shadow-[0_18px_35px_-24px_rgba(15,23,42,0.18)]"
          >
            <svg class="h-6 w-6 shrink-0 text-slate-700" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"></path>
            </svg>
            <div class="text-left">
              <div class="text-[10px] font-medium leading-none text-slate-500">Download now on</div>
              <div class="mt-0.5 font-dm-sans text-[15px] font-semibold leading-none text-slate-700">App Store</div>
            </div>
          </a>
        </div>

      </div>

      <div class="mt-6 w-full flex-1 overflow-visible lg:mt-0">
        <div class="flex items-center justify-center">
          <div class="rounded-[42px] border border-slate-200 bg-white/70 p-4 shadow-[0_24px_45px_-34px_rgba(15,23,42,0.35)]">
            <img
              src={phoneDemo.src}
              alt="Glu app home screen"
              class="h-auto w-full max-w-[360px] rounded-[32px] drop-shadow-[0_24px_44px_rgba(15,23,42,0.32)] lg:max-w-[420px]"
              width={phoneDemo.width}
              height={phoneDemo.height}
              loading="eager"
              fetchpriority="high"
              decoding="sync"
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

