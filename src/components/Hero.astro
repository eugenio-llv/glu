        <div class="mt-6 flex flex-wrap justify-center gap-2 lg:justify-start">
          <span class="rounded-full border border-blue-100 bg-white/80 px-3 py-1.5 text-xs font-medium text-slate-600">Injection and pill reminders</span>
          <span class="rounded-full border border-blue-100 bg-white/80 px-3 py-1.5 text-xs font-medium text-slate-600">Weight and symptom trends</span>
          <span class="rounded-full border border-blue-100 bg-white/80 px-3 py-1.5 text-xs font-medium text-slate-600">Meals, water, goals, and exercise</span>
        </div>

        <div class="mt-8 w-full max-w-xl rounded-2xl border border-slate-200/80 bg-white/72 p-3 shadow-[0_24px_50px_-34px_rgba(15,23,42,0.2)] backdrop-blur">
          <div id="waitlist-success" class="hidden rounded-xl border border-blue-200 bg-blue-50 px-5 py-4">
            <p class="font-dm-sans font-medium text-blue-900">You’re on the list.</p>
            <p class="mt-1 text-sm text-blue-700">We’ll email you when Glu is available.</p>
          </div>

          <form id="waitlist-form" class="flex flex-col gap-3 sm:flex-row">
            <label class="relative flex-1">
              <span class="sr-only">Email</span>
              <svg
                class="pointer-events-none absolute left-4 top-1/2 h-5 w-5 -translate-y-1/2 text-slate-400"
                viewBox="0 0 24 24"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                aria-hidden="true"
              >
                <path d="M4 7H20V17H4V7Z" stroke="currentColor" stroke-width="1.5"></path>
                <path d="M4 8L12 13L20 8" stroke="currentColor" stroke-width="1.5"></path>
              </svg>
              <input
                id="waitlist-email"
                type="email"
                name="email"
                placeholder="Enter your email"
                required
                class="w-full rounded-xl border border-slate-200 bg-white px-11 py-4 font-dm-sans text-base text-slate-900 placeholder:text-slate-400 transition-all duration-200 focus:border-blue-200 focus:outline-none focus:ring-4 focus:ring-blue-100 disabled:opacity-50"
              />
            </label>
            <button
              id="waitlist-submit"
              type="submit"
              class="whitespace-nowrap rounded-xl bg-slate-900 px-6 py-4 font-dm-sans text-base font-medium text-white shadow-[0_18px_35px_-24px_rgba(15,23,42,0.95)] transition-all duration-200 hover:-translate-y-0.5 hover:bg-slate-800 hover:shadow-[0_22px_35px_-22px_rgba(15,23,42,0.95)] disabled:cursor-not-allowed disabled:opacity-50"
            >
              Join waitlist
            </button>
          </form>

          <p id="waitlist-error" class="mt-3 hidden text-center text-sm text-red-500 lg:text-left">Something went wrong. Please try again.</p>
          <p id="waitlist-helper" class="mt-3 text-center text-sm text-slate-500 lg:text-left">Want first access when Glu launches? Join the waitlist.</p>
        </div>

      </div>

      <div class="mt-6 w-full flex-1 overflow-visible lg:mt-0">
        <div class="flex items-center justify-center">
          <img
            src={phoneDemo.src}
            alt="Glu app home screen"
            class="h-auto w-full max-w-[360px] drop-shadow-[0_24px_44px_rgba(15,23,42,0.32)] lg:max-w-[420px]"
            width={phoneDemo.width}
            height={phoneDemo.height}
            loading="eager"
            fetchpriority="high"
            decoding="sync"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  const form = document.getElementById('waitlist-form');
  const emailInput = document.getElementById('waitlist-email');
  const submitButton = document.getElementById('waitlist-submit');
  const helper = document.getElementById('waitlist-helper');
  const error = document.getElementById('waitlist-error');
  const success = document.getElementById('waitlist-success');

  if (
    form instanceof HTMLFormElement &&
    emailInput instanceof HTMLInputElement &&
    submitButton instanceof HTMLButtonElement &&
    helper instanceof HTMLElement &&
    error instanceof HTMLElement &&
    success instanceof HTMLElement
  ) {
    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      submitButton.disabled = true;
      submitButton.textContent = 'Joining...';
      error.classList.add('hidden');

      try {
        const response = await fetch('https://formfy.layline.ventures/glu@layline.ventures', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded'
          },
          body: new URLSearchParams({
            email: emailInput.value,
            _subject: 'New Glu Waitlist Signup'
          })
        });

        if (!response.ok) throw new Error('Request failed');

        form.classList.add('hidden');
        helper.classList.add('hidden');
        success.classList.remove('hidden');
        emailInput.value = '';
      } catch {
        error.classList.remove('hidden');
      } finally {
        submitButton.disabled = false;
        submitButton.textContent = 'Join waitlist';
      }
    });
  }
</script>
