---
const title = "Signing you in...";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="robots" content="noindex,nofollow" />
    <style>
      :root {
        color-scheme: light;
        --bg: #f6f7fb;
        --card: #ffffff;
        --text: #101828;
        --muted: #667085;
        --accent: #0f766e;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 24px;
        background:
          radial-gradient(circle at top, #e5f4f1 0%, transparent 45%),
          linear-gradient(180deg, #f9fbff 0%, var(--bg) 100%);
        font-family: system-ui, sans-serif;
        color: var(--text);
      }

      main {
        width: min(100%, 440px);
        background: var(--card);
        border-radius: 24px;
        padding: 28px;
        box-shadow: 0 24px 64px rgba(16, 24, 40, 0.1);
        text-align: center;
      }

      h1 {
        margin: 0 0 12px;
        font-size: 28px;
        line-height: 1.1;
      }

      p {
        margin: 0 0 18px;
        line-height: 1.5;
        color: var(--muted);
      }

      a.button {
        display: inline-block;
        text-decoration: none;
        border-radius: 999px;
        padding: 12px 18px;
        font-weight: 600;
        background: var(--accent);
        color: white;
      }

      .small {
        margin-top: 16px;
        font-size: 14px;
      }
    </style>
  </head>
  <body>
    <main>
      <h1>{title}</h1>
      <p id="status">Checking your sign-in link…</p>
      <a id="open-app" class="button" href="#">Open Glu</a>
      <p class="small">You can close this page after sign-in completes.</p>
    </main>

    <script>
      const status = document.getElementById("status");
      const openApp = document.getElementById("open-app");

      const current = new URL(window.location.href);
      const code = current.searchParams.get("code");
      const state = current.searchParams.get("state");
      const type = current.searchParams.get("type");
      const hasUnexpectedTokens =
        current.hash.includes("access_token") ||
        current.hash.includes("refresh_token") ||
        current.searchParams.has("access_token") ||
        current.searchParams.has("refresh_token") ||
        current.searchParams.has("token_hash");

      // Temporary migration fallback only.
      // Remove no later than March 31, 2026 once verified https opening is stable.
      const appParams = new URLSearchParams();
      if (code) appParams.set("code", code);
      if (state) appParams.set("state", state);
      if (type) appParams.set("type", type);
      const legacyUrl = `glu://login-callback?${appParams.toString()}`;
      openApp.href = legacyUrl;

      if (hasUnexpectedTokens) {
        status.textContent =
          "This sign-in link uses an outdated format. Return to Glu and request a new sign-in link.";
        openApp.setAttribute("aria-disabled", "true");
        openApp.href = "#";
      } else if (code) {
        status.textContent = "Trying to open Glu…";
        window.location.replace(legacyUrl);
      } else {
        status.textContent =
          "This sign-in link is missing required verification data. Return to Glu and request a new sign-in link.";
        openApp.setAttribute("aria-disabled", "true");
        openApp.href = "#";
      }
    </script>
  </body>
</html>
