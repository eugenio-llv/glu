---
import Layout from '../layouts/Layout.astro';
import SupportForm from '../components/SupportForm.tsx';
import Footer from '../components/Footer.astro';
---

<Layout title="Support - Glu">
  <div class="min-h-screen bg-slate-50 text-slate-900">
    <!-- Header -->
    <header class="sticky top-0 bg-white/80 backdrop-blur-xl z-50 border-b border-slate-100">
      <div class="max-w-4xl mx-auto px-6 sm:px-8 py-6">
        <a href="/" class="inline-flex items-center gap-3">
          <img src="/app_icon.png" alt="Glu" class="w-8 h-8 rounded-xl shadow-sm" />
          <span class="font-sora text-lg font-semibold text-slate-900 tracking-tight">Glu</span>
        </a>
      </div>
    </header>

    <!-- Content -->
    <main class="max-w-4xl mx-auto px-6 sm:px-8 pb-20">
      <!-- Title -->
      <div class="pt-16 sm:pt-24 pb-10 sm:pb-14">
        <span class="inline-flex items-center gap-2 rounded-full bg-slate-900/5 text-slate-700 px-3 py-1 text-xs font-semibold tracking-[0.2em] uppercase">
          Support
        </span>
        <h1 class="font-sora text-3xl sm:text-4xl lg:text-5xl font-semibold text-slate-900 mt-5 mb-3 tracking-tight">
          How can we help?
        </h1>
        <p class="font-dm-sans text-lg text-slate-500 leading-relaxed max-w-lg">
          Share feedback, report an issue, or ask about reminders, logs, goals, and app behavior.
        </p>
      </div>

      <!-- Form Card -->
      <div class="bg-white rounded-3xl border border-slate-100 shadow-[0_24px_60px_-50px_rgba(15,23,42,0.6)]">
        <div class="px-6 sm:px-10 lg:px-12 py-10 sm:py-12">
          <SupportForm client:load />
        </div>
      </div>

      <!-- Contact Info -->
      <div class="mt-12 text-center">
        <p class="font-dm-sans text-sm text-slate-400">
          You can also reach us directly at
          <a href="mailto:glu@layline.ventures" class="text-slate-600 hover:text-slate-900 underline decoration-slate-200 underline-offset-4 transition-colors">glu@layline.ventures</a>
        </p>
      </div>
    </main>

    <Footer />
  </div>
</Layout>
