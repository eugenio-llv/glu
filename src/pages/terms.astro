      <div class="max-w-4xl mx-auto px-6 sm:px-8 py-6">
        <a href="/" class="inline-flex items-center gap-3">
          <img src="/app_icon.png" alt="Glu" class="w-8 h-8 rounded-xl shadow-sm" />
          <span class="font-sora text-lg font-semibold text-slate-900 tracking-tight">Glu</span>
        </a>
      </div>
    </header>

    <!-- Content -->
    <main class="max-w-4xl mx-auto px-6 sm:px-8 pb-20">

      <!-- Title -->
      <div class="pt-16 sm:pt-24 pb-10 sm:pb-14">
        <span class="inline-flex items-center gap-2 rounded-full bg-slate-900/5 text-slate-700 px-3 py-1 text-xs font-semibold tracking-[0.2em] uppercase">
